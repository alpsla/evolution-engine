{
  "version": 2,
  "builds": [
    {
      "src": "api/telemetry.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/patterns.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/accept.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/adapter-request.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/create-checkout.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/get-license.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/activate-license.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "api/license-check.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "i18n.js",
      "use": "@vercel/static"
    },
    {
      "src": "i18n/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "robots.txt",
      "use": "@vercel/static"
    },
    {
      "src": "sitemap.xml",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.py" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/docs", "dest": "/docs.html" },
    { "src": "/docs.html", "dest": "/docs.html" },
    { "src": "/adapters", "dest": "/adapters.html" },
    { "src": "/adapters.html", "dest": "/adapters.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/privacy.html", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/terms.html", "dest": "/terms.html" },
    { "src": "/lawyer-review-packet-2026-02-22", "dest": "/lawyer-review-packet-2026-02-22.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/i18n.js", "dest": "/i18n.js" },
    { "src": "/i18n/(.*)", "dest": "/i18n/$1" },
    { "src": "/docs/integrations", "dest": "/integrations.html" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/googlee9024bf2caf1dcc2.html", "dest": "/googlee9024bf2caf1dcc2.html" },
    { "src": "/sample-report.html", "dest": "/sample-report.html" },
    { "src": "/sample-report-de.html", "dest": "/sample-report-de.html" },
    { "src": "/sample-report-es.html", "dest": "/sample-report-es.html" },
    { "src": "/sample-report-verify.html", "dest": "/sample-report-verify.html" },
    { "src": "/sample-report-verify-de.html", "dest": "/sample-report-verify-de.html" },
    { "src": "/sample-report-verify-es.html", "dest": "/sample-report-verify-es.html" },
    { "src": "/reports/aws-cdk", "dest": "/report-aws-cdk.html" },
    { "src": "/reports/workers-sdk", "dest": "/report-workers-sdk.html" },
    { "src": "/reports/google-cloud-python", "dest": "/report-google-cloud-python.html" },
    { "src": "/reports/vscode", "dest": "/report-vscode.html" },
    { "src": "/reports/uber-zap", "dest": "/report-zap.html" },
    { "src": "/reports/shopify-hydrogen", "dest": "/report-hydrogen.html" },
    { "src": "/reports/react", "dest": "/report-react.html" },
    { "src": "/reports/stripe-node", "dest": "/report-stripe-node.html" },
    { "src": "/reports/langchain", "dest": "/report-langchain.html" },
    { "src": "/reports/nextjs", "dest": "/report-nextjs.html" },
    { "src": "/reports/plaid-node", "dest": "/report-plaid-node.html" },
    { "src": "/reports/substation", "dest": "/report-substation.html" },
    { "src": "/reports/onchainkit", "dest": "/report-onchainkit.html" },
    { "src": "/reports/supabase", "dest": "/report-supabase.html" },
    { "src": "/reports/goose", "dest": "/report-goose.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
